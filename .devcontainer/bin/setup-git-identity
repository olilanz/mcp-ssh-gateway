#!/usr/bin/env bash
set -euo pipefail

# Persist git identity in a named Docker volume mounted at /opt/shared-git-identity
install -d -m 0755 /opt/shared-git-identity
touch /opt/shared-git-identity/.gitconfig
chmod 600 /opt/shared-git-identity/.gitconfig
chown vscode:vscode /opt/shared-git-identity /opt/shared-git-identity/.gitconfig

# Replace any regular file with symlink to shared location
if [ -e /home/vscode/.gitconfig ] && [ ! -L /home/vscode/.gitconfig ]; then
  rm -f /home/vscode/.gitconfig
fi

ln -sfn /opt/shared-git-identity/.gitconfig /home/vscode/.gitconfig
chown -h vscode:vscode /home/vscode/.gitconfig

echo "Git identity: /home/vscode/.gitconfig -> /opt/shared-git-identity/.gitconfig"
